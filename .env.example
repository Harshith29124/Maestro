# ---- Provider API keys ----
# Groq (OpenAI-compatible). Get one free at https://console.groq.com
GROQ_API_KEY=

# Google AI Studio (Gemini). Get one free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ---- App security (all optional; sane defaults applied) ----
# Comma-separated API keys clients must send as `X-API-Key` or `Authorization: Bearer <key>`.
# Leave empty to disable auth (fine for local; SET THIS before any public deploy).
MAESTRO_API_KEYS=

# Secret used to sign run-access tokens. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MAESTRO_SECRET_KEY=

# Comma-separated allowed CORS origins. Use exact origins in prod, e.g. https://maestro.example.com
# "*" is rejected when auth/credentials are on; default below is safe for local dev.
MAESTRO_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Per-client request budget (sliding window). Defaults are conservative for free deploys.
MAESTRO_RATE_LIMIT_PER_MINUTE=10
MAESTRO_RATE_LIMIT_PER_DAY=200

# Max characters accepted in a single task prompt (input hardening).
MAESTRO_MAX_PROMPT_CHARS=8000

# Set to "production" on Vercel/Railway to enforce strict security checks.
MAESTRO_ENV=development

# If true, the app serves with no provider keys using a deterministic mock provider
# (handy for demos / CI). Never enable in production with real traffic expectations.
MAESTRO_ALLOW_MOCK=true
